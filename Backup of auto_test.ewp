<?xml version="1.0" encoding="iso-8859-1"?>

<project>
  <fileVersion>3</fileVersion>
  <configuration>
    <name>Debug</name>
    <toolchain>
      <name>ARM</name>
    </toolchain>
    <debug>1</debug>
    <settings>
      <name>General</name>
      <arm>
        <data>
          <processor>STM32F103RBT6</processor>
          <fpu>VFP9-S</fpu>
        </data>
      </arm>
    </settings>
    <settings>
      <name>ICCARM</name>
      <arm>
        <data>
          <overrides>
            <entry>
              <key>CCDefines</key>
              <value>STM32F10X_MD, USE_STDPERIPH_DRIVER</value>
            </entry>
            <entry>
              <key>CCIncludePath2</key>
              <value>$PROJ_DIR$\CMSIS;$PROJ_DIR$\StdPeriph_Driver\inc;$PROJ_DIR$\MYDRIVER;$PROJ_DIR$\MYUSER;$PROJ_DIR$\SEGGER_RTT;$PROJ_DIR$\Core</value>
            </entry>
            <entry>
              <key>CCOptLevel</key>
              <value>1</value>
            </entry>
            <entry>
              <key>CCDebugInfo</key>
              <value>1</value>
            </entry>
          </overrides>
        </data>
      </arm>
    </settings>
    <settings>
      <name>AARM</name>
      <arm>
        <data>
          <overrides>
            <entry>
              <key>ADefines</key>
              <value>STM32F10X_MD</value>
            </entry>
          </overrides>
        </data>
      </arm>
    </settings>
    <settings>
      <name>ILINK</name>
      <arm>
        <data>
          <overrides>
            <entry>
              <key>IlinkIcfFile</key>
              <value>$TOOLKIT_DIR$\config\linker\ST\stm32f10xxb.icf</value>
            </entry>
            <entry>
              <key>IlinkEntryPoint</key>
              <value>Reset_Handler</value>
            </entry>
          </overrides>
        </data>
      </arm>
    </settings>
  </configuration>

  <group>
    <name>Core</name>
    <file>
      <name>$PROJ_DIR$\Core\main.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\Core\stm32f10x_it.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\Core\startup_stm32f10x_md.s</name>
    </file>
    <file>
      <name>$PROJ_DIR$\CMSIS\system_stm32f10x.c</name>
    </file>
  </group>

  <group>
    <name>StdPeriph_Driver</name>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\stm32f10x_gpio.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\stm32f10x_rcc.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\stm32f10x_tim.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\stm32f10x_adc.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\stm32f10x_flash.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\StdPeriph_Driver\src\misc.c</name>
    </file>
  </group>

  <group>
    <name>MYDRIVER</name>
    <file>
      <name>$PROJ_DIR$\MYDRIVER\drv_pwm.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\MYDRIVER\drv_adc.c</name>
    </file>
  </group>

  <group>
    <name>MYUSER</name>
    <file>
      <name>$PROJ_DIR$\MYUSER\mydev.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\MYUSER\mainprocess.c</name>
    </file>
    <file>
      <name>$PROJ_DIR$\MYUSER\my_rtt_debug.c</name>
    </file>
  </group>

  <group>
    <name>SEGGER_RTT</name>
    <file>
      <name>$PROJ_DIR$\SEGGER_RTT\SEGGER_RTT.c</name>
    </file>
  </group>
</project>
